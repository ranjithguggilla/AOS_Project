      "targets": [{ "expr": "100 * sum(kube_deployment_status_replicas_available{namespace=\"shop-micro\",deployment=~\"api-gateway|user-service|product-service|cart-service|order-service|payment-service|review-service\"}) / clamp_min(sum(kube_deployment_spec_replicas{namespace=\"shop-micro\",deployment=~\"api-gateway|user-service|product-service|cart-service|order-service|payment-service|review-service\"}), 1)", "refId": "A" }]
