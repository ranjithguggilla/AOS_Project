        { "expr": "rate(http_requests_total{service=\"cart-service\"}[1m])", "legendFormat": "cart-service", "refId": "D" },
        { "expr": "rate(http_requests_total{service=\"order-service\"}[1m])", "legendFormat": "order-service", "refId": "E" },
        { "expr": "rate(http_requests_total{service=\"payment-service\"}[1m])", "legendFormat": "payment-service", "refId": "F" },
        { "expr": "rate(http_requests_total{service=\"review-service\"}[1m])", "legendFormat": "review-service", "refId": "G" }
      ]
    },
