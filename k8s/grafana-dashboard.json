        { "expr": "nodejs_heap_size_used_bytes{service=\"order-service\"}", "legendFormat": "order-service", "refId": "C" },
        { "expr": "nodejs_heap_size_used_bytes{service=\"cart-service\"}", "legendFormat": "cart-service", "refId": "D" },
        { "expr": "nodejs_heap_size_used_bytes{service=\"api-gateway\"}", "legendFormat": "api-gateway", "refId": "E" }
