      "title": "HTTP Request Rate by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_requests_total{service=\"api-gateway\"}[1m])", "legendFormat": "api-gateway", "refId": "A" },
        { "expr": "rate(http_requests_total{service=\"user-service\"}[1m])", "legendFormat": "user-service", "refId": "B" },
