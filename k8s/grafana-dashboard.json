        { "expr": "kube_deployment_status_replicas_available{namespace=\"shop-micro\",deployment=~\"api-gateway|user-service|product-service|cart-service|order-service|payment-service|review-service\"}", "legendFormat": "available {{deployment}}", "refId": "B" }
